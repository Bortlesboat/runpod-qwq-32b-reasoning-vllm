{
  "title": "QwQ 32B Reasoning vLLM Worker",
  "description": "An H100-focused RunPod Hub worker for Qwen/QwQ-32B with OpenAI-compatible routing and presets tuned for longer reasoning-style outputs.",
  "type": "serverless",
  "category": "language",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 40,
    "gpuCount": 1,
    "gpuIds": "ADA_80_PRO",
    "allowedCudaVersions": [
      "12.8",
      "12.7",
      "12.6",
      "12.5",
      "12.4",
      "12.3",
      "12.2",
      "12.1"
    ],
    "presets": [
      {
        "name": "Balanced QwQ 32B",
        "defaults": {
          "MODEL_NAME": "Qwen/QwQ-32B",
          "MAX_MODEL_LEN": 16384,
          "GPU_MEMORY_UTILIZATION": 0.9,
          "MAX_NUM_SEQS": 24,
          "TENSOR_PARALLEL_SIZE": 1,
          "DTYPE": "bfloat16",
          "DEFAULT_MAX_TOKENS": 1024,
          "MAX_CONCURRENCY": 6
        }
      },
      {
        "name": "Long Reasoning QwQ 32B",
        "defaults": {
          "MODEL_NAME": "Qwen/QwQ-32B",
          "MAX_MODEL_LEN": 32768,
          "GPU_MEMORY_UTILIZATION": 0.92,
          "MAX_NUM_SEQS": 12,
          "TENSOR_PARALLEL_SIZE": 1,
          "DTYPE": "bfloat16",
          "DEFAULT_MAX_TOKENS": 1536,
          "MAX_CONCURRENCY": 3
        }
      },
      {
        "name": "High Throughput QwQ 32B",
        "defaults": {
          "MODEL_NAME": "Qwen/QwQ-32B",
          "MAX_MODEL_LEN": 8192,
          "GPU_MEMORY_UTILIZATION": 0.9,
          "MAX_NUM_SEQS": 32,
          "TENSOR_PARALLEL_SIZE": 1,
          "DTYPE": "bfloat16",
          "DEFAULT_MAX_TOKENS": 768,
          "MAX_CONCURRENCY": 8
        }
      }
    ],
    "env": [
      {
        "key": "MODEL_NAME",
        "input": {
          "type": "huggingface",
          "name": "Model",
          "description": "Hugging Face repo id or local model path for vLLM.",
          "default": "Qwen/QwQ-32B",
          "required": true
        }
      },
      {
        "key": "HF_TOKEN",
        "input": {
          "type": "string",
          "name": "Hugging Face token",
          "description": "Optional access token for gated or private models.",
          "advanced": true
        }
      },
      {
        "key": "MAX_MODEL_LEN",
        "input": {
          "type": "number",
          "name": "Max model length",
          "description": "Context window cap passed to vLLM. Lower this first if you need to save VRAM.",
          "min": 512,
          "max": 131072,
          "default": 16384
        }
      },
      {
        "key": "GPU_MEMORY_UTILIZATION",
        "input": {
          "type": "number",
          "name": "GPU memory utilization",
          "description": "Fraction of GPU memory that vLLM is allowed to reserve.",
          "min": 0.5,
          "max": 0.99,
          "default": 0.9
        }
      },
      {
        "key": "MAX_NUM_SEQS",
        "input": {
          "type": "number",
          "name": "Max sequences",
          "description": "Maximum concurrent sequences scheduled by vLLM.",
          "min": 1,
          "max": 512,
          "default": 24
        }
      },
      {
        "key": "TENSOR_PARALLEL_SIZE",
        "input": {
          "type": "number",
          "name": "Tensor parallel size",
          "description": "Number of GPUs to shard the model across.",
          "min": 1,
          "max": 8,
          "default": 1
        }
      },
      {
        "key": "DTYPE",
        "input": {
          "type": "string",
          "name": "dtype",
          "description": "Numerical precision used by vLLM.",
          "options": [
            {
              "label": "Auto",
              "value": "auto"
            },
            {
              "label": "bfloat16",
              "value": "bfloat16"
            },
            {
              "label": "float16",
              "value": "float16"
            }
          ],
          "default": "bfloat16"
        }
      },
      {
        "key": "TOKENIZER_MODE",
        "input": {
          "type": "string",
          "name": "Tokenizer mode",
          "description": "Optional tokenizer mode for families like Mistral.",
          "options": [
            {
              "label": "Default",
              "value": ""
            },
            {
              "label": "mistral",
              "value": "mistral"
            }
          ],
          "default": "",
          "advanced": true
        }
      },
      {
        "key": "CONFIG_FORMAT",
        "input": {
          "type": "string",
          "name": "Config format",
          "description": "Optional config format override for models like Mistral.",
          "options": [
            {
              "label": "Default",
              "value": ""
            },
            {
              "label": "mistral",
              "value": "mistral"
            }
          ],
          "default": "",
          "advanced": true
        }
      },
      {
        "key": "LOAD_FORMAT",
        "input": {
          "type": "string",
          "name": "Load format",
          "description": "Optional load format override for specialized model families.",
          "options": [
            {
              "label": "Default",
              "value": ""
            },
            {
              "label": "mistral",
              "value": "mistral"
            }
          ],
          "default": "",
          "advanced": true
        }
      },
      {
        "key": "QUANTIZATION",
        "input": {
          "type": "string",
          "name": "Quantization",
          "description": "Optional quantization mode for supported models.",
          "options": [
            {
              "label": "None",
              "value": ""
            },
            {
              "label": "AWQ",
              "value": "awq"
            },
            {
              "label": "GPTQ",
              "value": "gptq"
            },
            {
              "label": "bitsandbytes",
              "value": "bitsandbytes"
            }
          ],
          "default": ""
        }
      },
      {
        "key": "TRUST_REMOTE_CODE",
        "input": {
          "type": "boolean",
          "name": "Trust remote code",
          "description": "Enable this only for models that require custom code from Hugging Face.",
          "default": false,
          "trueValue": "true",
          "falseValue": "false"
        }
      },
      {
        "key": "ENABLE_AUTO_TOOL_CHOICE",
        "input": {
          "type": "boolean",
          "name": "Auto tool choice",
          "description": "Enable vLLM auto tool selection for supported tool-calling models.",
          "default": false,
          "trueValue": "true",
          "falseValue": "false",
          "advanced": true
        }
      },
      {
        "key": "TOOL_CALL_PARSER",
        "input": {
          "type": "string",
          "name": "Tool call parser",
          "description": "Parser selection for tool-calling models.",
          "options": [
            {
              "label": "llama3_json",
              "value": "llama3_json"
            },
            {
              "label": "hermes",
              "value": "hermes"
            },
            {
              "label": "mistral",
              "value": "mistral"
            },
            {
              "label": "granite",
              "value": "granite"
            },
            {
              "label": "deepseek_v3",
              "value": "deepseek_v3"
            }
          ],
          "default": "llama3_json",
          "advanced": true
        }
      },
      {
        "key": "REASONING_PARSER",
        "input": {
          "type": "string",
          "name": "Reasoning parser",
          "description": "Optional parser for reasoning-capable model families like DeepSeek-R1.",
          "options": [
            {
              "label": "Default",
              "value": ""
            },
            {
              "label": "deepseek_r1",
              "value": "deepseek_r1"
            }
          ],
          "default": "",
          "advanced": true
        }
      },
      {
        "key": "ENFORCE_EAGER",
        "input": {
          "type": "boolean",
          "name": "Enforce eager",
          "description": "Useful for edge-case startup issues on some model and CUDA combinations.",
          "default": false,
          "trueValue": "true",
          "falseValue": "false",
          "advanced": true
        }
      },
      {
        "key": "OPENAI_SERVED_MODEL_NAME_OVERRIDE",
        "input": {
          "type": "string",
          "name": "Served model name override",
          "description": "Optional alias returned by the OpenAI-compatible API.",
          "advanced": true
        }
      },
      {
        "key": "DEFAULT_MAX_TOKENS",
        "input": {
          "type": "number",
          "name": "Default max tokens",
          "description": "Fallback max_tokens used when the request does not specify one.",
          "min": 16,
          "max": 4096,
          "default": 1024
        }
      },
      {
        "key": "MAX_CONCURRENCY",
        "input": {
          "type": "number",
          "name": "Max concurrency",
          "description": "Maximum number of RunPod handler requests allowed in-flight at once.",
          "min": 1,
          "max": 128,
          "default": 6
        }
      }
    ]
  }
}
